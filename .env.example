# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FLASK_ENV=development
SECRET_KEY=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Database
DB_PATH=./data/affiliate.db

# Amazon PA-API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=
AMAZON_COUNTRY=IN

# Flipkart Affiliate API
FLIPKART_API_KEY=
FLIPKART_AFFILIATE_ID=

# eBay Browse API
EBAY_APP_ID=
EBAY_CERT_ID=

# Meesho Scraper (comma-separated proxy list)
MEESHO_PROXY_POOL=

# Croma Scraper (comma-separated proxy list)
CROMA_PROXY_POOL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Scraping API Provider (for Amazon / anti-bot protection)
# Options: scrapedo, zenrows, oxylabs, or leave empty for direct fetch
SCRAPING_API_PROVIDER=
SCRAPING_API_KEY=

# Reverse Image Search (Google Lens via SerpAPI)
SERPAPI_KEY=

# ASIN to UPC/EAN Conversion (EasyParser or compatible)
EASYPARSER_API_KEY=

# Resend (email alerts)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=alerts@luminacommerce.com

# Logging
LOG_LEVEL=info
